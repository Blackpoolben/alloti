{
  "expo": {
    "name": "Alloti",
    "slug": "alloti",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alloti.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Alloti uses your camera to identify plants and photograph your garden.",
        "NSPhotoLibraryUsageDescription": "Alloti can identify plants from your photos and save garden journal images.",
        "NSLocationWhenInUseUsageDescription": "Alloti uses your location for more accurate plant identification.",
        "NSUserNotificationsUsageDescription": "Alloti sends seasonal planting and pruning reminders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.alloti.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Alloti to access your location for plant identification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D6A4F",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "alloti-app"
      }
    }
  }
}
